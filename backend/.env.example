# ──────────────────────────────────────────────
# FamiCare Backend Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# PostgreSQL (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+asyncpg://famicare:famicare_secret@localhost:5432/famicare_db

# LINE Messaging API
# Get these from: https://developers.line.biz/console/
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# LINE Login (OAuth)
LINE_LOGIN_CHANNEL_ID=your_line_login_channel_id_here
LINE_LOGIN_CHANNEL_SECRET=your_line_login_channel_secret_here
LINE_LOGIN_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Google Gemini AI
# Get this from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Application
APP_ENV=development
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Image Upload
UPLOAD_DIR=./uploads
